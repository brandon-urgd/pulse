__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Local dev/debug scripts — not for CI
scripts/dev/

# ── Vitest / test cache ───────────────────────────────────────────────────────
.vitest-cache/
vitest.config.*.timestamp*

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Runtime data ──────────────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ── Coverage ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

